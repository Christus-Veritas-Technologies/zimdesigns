generator client {
  provider = "prisma-client"
  output   = "../generated"
  moduleFormat = "esm"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  name               String
  username           String         @unique
  passwordHash       String?
  googleId           String?        @unique
  avatarUrl          String?
  bio                String?
  role               String?
  location           String?
  interests          String         @default("[]")
  onboardingComplete Boolean        @default(false)
  emailVerified      Boolean        @default(false)
  pushToken          String?
  linkedinUrl        String?
  githubUrl          String?
  dribbbleUrl        String?
  twitterUrl         String?
  websiteUrl         String?
  figmaUrl           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  refreshTokens      RefreshToken[]
  redesigns          Redesign[]
  upvotes            Upvote[]
  comments           Comment[]
  notifications      Notification[]
  bookmarks          Bookmark[]
  following          Follow[]       @relation("Follower")
  followers          Follow[]       @relation("Following")
  appRequests             AppRequest[]
  appRequestVotes         AppRequestVote[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}


model AppEntry {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  iconColor   String   @default("#E8A900")
  iconLetter  String
  description String?
  tags        String   @default("[]")
  brokenItems String   @default("[]")
  screenshotUrl String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Redesign {
  id          String   @id @default(cuid())
  title       String
  appName     String
  description String?
  beforeUrl   String
  afterUrl    String
  authorId    String
  tags        String   @default("[]")
  upvoteCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  upvotes     Upvote[]
  comments    Comment[]
  bookmarks   Bookmark[]
}


model Upvote {
  id         String   @id @default(cuid())
  userId     String
  redesignId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  redesign   Redesign @relation(fields: [redesignId], references: [id], onDelete: Cascade)

  @@unique([userId, redesignId])
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  authorId   String
  redesignId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  redesign   Redesign @relation(fields: [redesignId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  body      String
  refId     String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  redesignId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId],     references: [id], onDelete: Cascade)
  redesign   Redesign @relation(fields: [redesignId], references: [id], onDelete: Cascade)

  @@unique([userId, redesignId])
}

model AppRequest {
  id          String   @id @default(cuid())
  appName     String
  description String?
  requesterId String
  voteCount   Int      @default(0)
  status      String   @default("open")
  createdAt   DateTime @default(now())

  requester   User             @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  votes       AppRequestVote[]
}

model AppRequestVote {
  id           String   @id @default(cuid())
  userId       String
  appRequestId String
  createdAt    DateTime @default(now())

  user         User       @relation(fields: [userId],       references: [id], onDelete: Cascade)
  appRequest   AppRequest @relation(fields: [appRequestId], references: [id], onDelete: Cascade)

  @@unique([userId, appRequestId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
