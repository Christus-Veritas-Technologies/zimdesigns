{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@hono/zod-validator": "^0.4.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@zimdesigns/db": "workspace:*",
    "@zimdesigns/env": "workspace:*",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "jose": "^6.2.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@zimdesigns/config": "workspace:*",
    "prisma": "^7.8.0",
    "tsdown": "^0.21.9",
    "tsx": "^4.22.4",
    "typescript": "catalog:"
  }
}
