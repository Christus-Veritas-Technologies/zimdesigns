# Database
DATABASE_URL="postgresql://user:password@localhost:5432/zimdesigns"

# Server
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# JWT — generate secrets with: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me-at-least-32-characters-long"
JWT_REFRESH_SECRET="change-me-different-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth — https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Web app URL (used to redirect native OAuth back to the app)
WEB_URL="http://localhost:3000"

# Cloudflare R2 — https://dash.cloudflare.com/ → R2 → Manage R2 API tokens
# Bucket must have public access enabled for images to load
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="zimdesigns"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# Email (Resend) — https://resend.com/api-keys
# If omitted, emails are logged to console (development mode)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="ZimDesigns <noreply@zimdesigns.com>"
