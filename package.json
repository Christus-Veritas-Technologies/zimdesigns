{
  "name": "zimdesigns",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @zimdesigns/db db:push",
    "db:studio": "turbo -F @zimdesigns/db db:studio",
    "db:generate": "turbo -F @zimdesigns/db db:generate",
    "db:migrate": "turbo -F @zimdesigns/db db:migrate"
  },
  "dependencies": {
    "@zimdesigns/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@zimdesigns/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.4.0"
}
